---
import astroLogo from '../../assets/astro.svg';
import background from '../../assets/background.svg';
---

<div class="h-full font-sans flex flex-col md:block">
	<img class="fixed inset-0 w-full h-full -z-10 blur-[100px]" src={background.src} alt="" fetchpriority="high" />
	<main class="h-full flex justify-center">
		<section class="block pt-[10%] p-4 md:flex md:flex-col md:items-start md:justify-center md:pt-4">
			<a href="https://astro.build"
				><img src={astroLogo.src} width="115" height="48" alt="Astro Homepage" /></a
			>
			<h1 class="text-[22px] mt-1 leading-[1.5] md:leading-tight">
				To get started, open the <code class="inline-block bg-[linear-gradient(66.77deg,#f3cddd_0%,#f5cee7_100%)_padding-box,linear-gradient(155deg,#d83333_0%,#f041ff_18%,#f5cee7_45%)_border-box] rounded-lg border border-transparent px-2 py-1.5"><pre class="font-mono bg-[linear-gradient(14deg,#d83333_0%,#f041ff_100%)] bg-clip-text text-transparent m-0">src/pages</pre></code> directory in your project.
			</h1>
			<section class="flex gap-4 flex-wrap md:flex-nowrap py-4">
				<a class="flex items-center px-3 py-2 text-white bg-[linear-gradient(83.21deg,#3245ff_0%,#bc52ee_100%)] shadow-[inset_0_0_0_1px_rgba(255,255,255,0.12),inset_0_-2px_0_rgba(0,0,0,0.24)] rounded-[10px] no-underline transition-colors hover:text-[#e6e6e6] hover:shadow-none" href="https://docs.astro.build">Read our docs</a>
				<a class="flex items-center px-3 py-2 text-[#111827] no-underline transition-colors hover:text-[#4e5056]" href="https://astro.build/chat"
					>Join our Discord <svg class="h-[1em] ml-2" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 127.14 96.36"
						><path
							fill="currentColor"
							d="M107.7 8.07A105.15 105.15 0 0 0 81.47 0a72.06 72.06 0 0 0-3.36 6.83 97.68 97.68 0 0 0-29.11 0A72.37 72.37 0 0 0 45.64 0a105.89 105.89 0 0 0-26.25 8.09C2.79 32.65-1.71 56.6.54 80.21a105.73 105.73 0 0 0 32.17 16.15 77.7 77.7 0 0 0 6.89-11.11 68.42 68.42 0 0 1-10.85-5.18c.91-.66 1.8-1.34 2.66-2a75.57 75.57 0 0 0 64.32 0c.87.71 1.76 1.39 2.66 2a68.68 68.68 0 0 1-10.87 5.19 77 77 0 0 0 6.89 11.1 105.25 105.25 0 0 0 32.19-16.14c2.64-27.38-4.51-51.11-18.9-72.15ZM42.45 65.69C36.18 65.69 31 60 31 53s5-12.74 11.43-12.74S54 46 53.89 53s-5.05 12.69-11.44 12.69Zm42.24 0C78.41 65.69 73.25 60 73.25 53s5-12.74 11.44-12.74S96.23 46 96.12 53s-5.04 12.69-11.43 12.69Z"
						></path></svg
					>
				</a>
			</section>
		</section>
	</main>

	<a href="https://astro.build/blog/astro-6-beta/" class="absolute bottom-10 inset-x-4 max-w-full md:inset-x-auto md:right-4 md:bottom-4 md:max-w-[300px] p-4 bg-white/100 border border-white rounded-2xl no-underline transition-colors backdrop-blur-[50px] hover:bg-white/55 hidden [@media(min-height:369px)]:block">
		<svg width="32" height="32" fill="none" xmlns="http://www.w3.org/2000/svg"
			><path
				d="M24.667 12c1.333 1.414 2 3.192 2 5.334 0 4.62-4.934 5.7-7.334 12C18.444 28.567 18 27.456 18 26c0-4.642 6.667-7.053 6.667-14Zm-5.334-5.333c1.6 1.65 2.4 3.43 2.4 5.333 0 6.602-8.06 7.59-6.4 17.334C13.111 27.787 12 25.564 12 22.666c0-4.434 7.333-8 7.333-16Zm-6-5.333C15.111 3.555 16 5.556 16 7.333c0 8.333-11.333 10.962-5.333 22-3.488-.774-6-4-6-8 0-8.667 8.666-10 8.666-20Z"
				fill="#111827"></path></svg
		>
		<h2 class="m-0 mb-4 font-normal text-[#111827] text-[20px]">What's New in Astro 6.0?</h2>
		<p class="text-[#4b5563] text-[16px] leading-6 tracking-[-0.006em] m-0">
			Redesigned dev server, fonts, live collections, built-in CSP support, and more! Click to
			explore Astro 6.0's new features.
		</p>
	</a>
</div>
