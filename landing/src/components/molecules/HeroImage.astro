---
// HeroImage Component
import { Image } from "astro:assets";
import { cn } from "../../utils/cn";
import type { HTMLAttributes } from "astro/types";
import Icon from "../atoms/Icon.astro";

interface Props extends HTMLAttributes<"div"> {
  variant?: "decorator" | "basic";
  href?: string;
  src?: ImageMetadata;
  alt: string;
  title?: string;
  class?: string;
}

const {
  src,
  alt,
  title,
  href,
  variant = "decorator",
  class: className,
  ...rest
} = Astro.props;

const variants = {
  decorator: "hero-decorator",
  basic: "hero-basic",
};

const Element = href ? "a" : "div";
---

<div
  class={cn(
    "relative group",
    variant === "decorator" && "p-4",
    className,
  )}
  {...rest}
>
  {
    variant === "decorator" && (
      <>
        <div class="absolute inset-0 rounded-2xl bg-brand-primary/20 -rotate-3 will-change-transform [backface-visibility:hidden] transition-all duration-[400ms] ease-[cubic-bezier(0.34,1.56,0.64,1)] group-hover:rotate-0 group-hover:translate-x-2 group-hover:-translate-y-2" />
        <div class="absolute inset-4 rounded-2xl bg-brand-secondary/10 -rotate-3 will-change-transform [backface-visibility:hidden] transition-all duration-[400ms] ease-[cubic-bezier(0.34,1.56,0.64,1)] group-hover:rotate-0 group-hover:translate-x-2 group-hover:-translate-y-2" />
      </>
    )
  }

  <Element
    href={href}
    class="relative block aspect-[4/5] rounded-2xl overflow-hidden shadow-image"
  >
    {
      src ? (
        <Image
          src={src}
          alt={alt}
          loading="eager"
          decoding="async"
          class={cn(
            "w-full h-full object-cover block [backface-visibility:hidden]",
            variant === "basic" && "will-change-transform transition-transform duration-500 ease-[cubic-bezier(0.25,0.46,0.45,0.94)] group-hover:scale-[1.06]"
          )}
        />
      ) : (
        <div class="absolute inset-0 flex items-center justify-center text-brand-secondary/30">
          <Icon name="Image" size={64} />
        </div>
      )
    }

    {
      title && (
        <span class="absolute bottom-4 left-4 right-4 text-white font-extrabold text-caption uppercase tracking-[0.1em] [text-shadow:--shadow-title]">
          {title}
        </span>
      )
    }
  </Element>
</div>

