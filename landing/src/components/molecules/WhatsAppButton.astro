---
import Button from "../atoms/Button.astro";
import Icon from "../atoms/Icon.astro";
import { getConfig } from "../../lib/api/getConfig";
import { formatPhoneForWhatsApp } from "../../utils/phone";
import { DEFAULT_CONTACT } from "../../lib/constants";

const config = await getConfig();
const phone = config?.contact_phone || DEFAULT_CONTACT.phone;
const whatsappUrl = `https://wa.me/${formatPhoneForWhatsApp(phone)}`;
---

<div class="fixed bottom-6 right-6 z-50">
  <Button 
    href={whatsappUrl} 
    target="_blank" 
    aria-label="Contactar por WhatsApp"
    class="!rounded-full !p-4 shadow-lg hover:shadow-xl transition-all duration-300 bg-[#25D366] hover:bg-[#128C7E] !border-none"
  >
    <Icon name="MessageCircle" class="w-8 h-8 text-white" />
  </Button>
</div>
